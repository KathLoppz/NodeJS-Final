<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Buscar Paciente</title>
    <style>
        body { background-color: #f0f4f8; font-family: 'Segoe UI', sans-serif; }
        .navbar-custom { background-color: #1a3c5e; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark navbar-custom px-4 py-3">
        <span class="navbar-brand fw-bold"><h2 class="fw-bold">Buscar Paciente</h2></span>
    </nav>

    <div class="d-flex justify-content-between align-items-center px-3 my-3">
        <a href="/" class="btn btn-dark">← Inicio</a>
    </div>

    <div class="container">
        <form action="/consulta-buscar" method="get" class="mb-4">
            <div class="input-group mx-auto" style="max-width:500px;">
                <input type="text" name="nombre" class="form-control"
                    placeholder="Buscar por nombre o apellido..."
                    value="<%= busqueda %>">
                <button type="submit" class="btn btn-dark">Buscar</button>
            </div>
        </form>

        <div class="table-responsive mx-auto p-2" style="max-width:800px;">
            <table class="table table-striped table-hover align-middle border">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Diagnóstico</th>
                        <th>Fecha Ingreso</th>
                        <th>Fecha Alta</th>
                        <th>Sala</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (lista.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted">No se encontraron resultados</td></tr>
                    <% } else { %>
                        <% lista.forEach(item => { %>
                        <tr>
                            <td><%= item.nombre %></td>
                            <td><%= item.apellido %></td>
                            <td><%= item.diagnostico %></td>
                            <td><%= item.fecha_ingreso ? new Date(item.fecha_ingreso).toISOString().split('T')[0] : '—' %></td>
                            <td><%= item.fecha_alta ? new Date(item.fecha_alta).toISOString().split('T')[0] : '—' %></td>
                            <td><%= item.sala || '—' %></td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>