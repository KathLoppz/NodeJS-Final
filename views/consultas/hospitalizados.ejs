<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Pacientes Hospitalizados</title>
    <style>
        body { background-color: #f0f4f8; font-family: 'Segoe UI', sans-serif; }
        .navbar-custom { background-color: #1a3c5e; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark navbar-custom px-4 py-3">
        <span class="navbar-brand fw-bold text-center">
            <h2 class="fw-bold">Pacientes Hospitalizados Actualmente</h2>
        </span>
    </nav>

    <div class="d-flex justify-content-between align-items-center px-3 my-3">
        <a href="/" class="btn btn-dark">← Inicio</a>
        <span class="badge bg-dark fs-6"><%= lista.length %> pacientes</span>
    </div>

    <div class="table-responsive mx-auto p-2" style="max-width:800px;">
        <table class="table table-striped table-hover align-middle border">
            <thead >
                <tr>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Diagnostico</th>
                    <th>Fecha Ingreso</th>
                    <th>Sala</th>
                </tr>
            </thead>
            <tbody>
                <% if (lista.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-center text-muted">No hay pacientes hospitalizados actualmente</td>
                    </tr>
                <% } else { %>
                    <% lista.forEach(item => { %>
                    <tr>
                        <td><%= item.nombre %></td>
                        <td><%= item.apellido %></td>
                        <td><%= item.diagnostico %></td>
                        <td><%= new Date(item.fecha_ingreso).toISOString().split('T')[0] %></td>
                        <td><span class="text-success"><%= item.sala %></span></td>
                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>